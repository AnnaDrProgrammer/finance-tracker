{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"],

    /* Важно: Убираем noEmit или меняем на false */
    "noEmit": false,

    /* Для composite проектов нужно указать outDir */
    "outDir": "./dist/node",

    /* Включаем генерацию деклараций */
    "declaration": true,
    "declarationMap": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts"]
}
